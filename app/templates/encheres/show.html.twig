{% extends 'base.html.twig' %}

{% block title %} Détail Enchères{% endblock %}

{% block body %}
<div class="mb-5">
    <h1>Détails d'enchère</h1>
</div>
<div class="card mb-3">
  <h3 class="card-header">{{ item.title}}</h3>
  <div class="card-body">
    <h5 class="card-title"><span>Prix de départ : </span>{{ item.StartingPrice ~ ' €'}}</h5>
    <h6 class="card-subtitle text-muted">{{ item.status == 'unpublished' ? 'Enchère non ouverte' : (item.status == 'published' ? 'Enchère ouverte': 'Enchère clôturé')}}</h6>
  </div>

  <div class="card-body">
    <p class="card-text">{{ item.description}}</p>
  </div>
  
</div>

{% endblock %}
