{% extends 'base.html.twig' %}

{% block title %}Hello EncheresController!{% endblock %}

{% block body %}
<div>
    <h1>TOP ENCHÈRE</h1>
</div>
<div class="d-flex flex-row flex-wrap gap-4 justify-content-center">
    {% for item in items %}       
        <div class="card border-primary " style=" min-width: 250px">
            <div class="card-header fw-bold">{{ item.title}}</div>
            <div class="card-body">
                <h4 class="card-title">{{item.StartingPrice ~ ' €'}}</h4>
                <span class="card-text fs-4">{{item.status}}</span>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
